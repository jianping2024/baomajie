generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id        String    @id @default(cuid())
  code      String    @unique
  nameZh    String
  nameLocal String?
  status    String    @default("active")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  regions   Region[]
  categories Category[]
  listings  Listing[]
  articles  Article[]
  crawlPages CrawlPage[]
}

model Region {
  id          String   @id @default(cuid())
  countryId   String
  parentId    String?
  slug        String
  nameZh      String
  nameLocal   String?
  regionType  String   @default("city")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  country  Country   @relation(fields: [countryId], references: [id], onDelete: Cascade)
  parent   Region?   @relation("RegionTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Region[]  @relation("RegionTree")
  listings Listing[]
  articles Article[]

  @@unique([countryId, slug])
  @@index([countryId, regionType])
}

model Category {
  id              String   @id @default(cuid())
  countryId       String
  parentCategoryId String?
  domain          String
  slug            String
  nameZh          String
  nameLocal       String?
  status          String   @default("active")
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  parent  Category? @relation("CategoryTree", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  listings Listing[]
  articles Article[]
  crawlPages CrawlPage[]

  @@unique([countryId, slug])
  @@index([countryId, domain])
}

model Listing {
  id                String   @id @default(cuid())
  ownerUserId       String?
  organizationId    String?
  countryId         String
  regionId          String?
  categoryId        String?
  title             String
  slug              String
  summary           String?
  description       String?
  priceAmount       Decimal?  @db.Decimal(12, 2)
  currencyCode      String?   @db.VarChar(3)
  priceType         String?   @default("fixed")
  conditionType     String?
  contactMethodJson Json?
  featured          Boolean   @default(false)
  tags              String[]  @default([])
  relatedSlugs      String[]  @default([])
  status            String    @default("published")
  moderationReason  String?
  publishedAt       DateTime?
  expiresAt         DateTime?
  viewCount         Int       @default(0)
  favoriteCount     Int       @default(0)
  sourceType        String
  sourceId          String?
  sourceUrl         String
  contentChecksum   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  country  Country        @relation(fields: [countryId], references: [id], onDelete: Cascade)
  region   Region?        @relation(fields: [regionId], references: [id], onDelete: SetNull)
  category Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  media    ListingMedia[]

  @@unique([sourceType, sourceId])
  @@unique([countryId, slug])
  @@index([countryId, status, publishedAt])
  @@index([countryId, categoryId, regionId, publishedAt])
  @@index([countryId, featured, publishedAt])
}

model Media {
  id           String   @id @default(cuid())
  kind         String
  storageKey   String?
  originalUrl  String?
  mimeType     String?
  width        Int?
  height       Int?
  sha256       String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listings ListingMedia[]
}

model ListingMedia {
  listingId  String
  mediaId    String
  sortOrder  Int      @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([listingId, mediaId])
  @@index([mediaId, sortOrder])
}

model Article {
  id             String   @id @default(cuid())
  authorUserId   String?
  countryId      String
  regionId       String?
  categoryId     String?
  articleType    String   @default("news")
  title          String
  slug           String
  summary        String?
  content        String?
  sourceName     String?
  sourceUrl      String?
  factCheckStatus String  @default("unchecked")
  status         String   @default("draft")
  publishedAt    DateTime?
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  region  Region?  @relation(fields: [regionId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  crawlPages CrawlPage[]

  @@unique([countryId, slug])
  @@index([countryId, articleType, publishedAt])
}

model CrawlPage {
  id            String   @id @default(cuid())
  countryId     String
  categoryId    String?
  articleId     String?
  pageType      String
  sourceId      String?
  sourceUrl     String   @unique
  canonicalUrl  String?
  contentChecksum String?
  httpStatus    Int?
  fetchedAt     DateTime?
  parsedAt      DateTime?
  status        String   @default("fetched")
  payloadJson   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([countryId, pageType])
  @@index([countryId, sourceId])
}

model ImportJob {
  id               String   @id @default(cuid())
  source           String
  type             String
  status           String   @default("queued")
  startedAt        DateTime?
  completedAt      DateTime?
  totalRows        Int      @default(0)
  successRows      Int      @default(0)
  failedRows       Int      @default(0)
  errorSummaryJson Json?
  createdAt        DateTime @default(now())

  errors ImportJobError[]
}

model ImportJobError {
  id               String   @id @default(cuid())
  importJobId      String
  sourceRecordId   String?
  errorCode        String
  errorMessage     String
  sourcePayloadJson Json?
  createdAt        DateTime @default(now())

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId, errorCode])
}

model LegacyMapping {
  id             String   @id @default(cuid())
  sourceSystem   String
  entityType     String
  legacyId       String
  newId          String
  sourceUrl      String?
  checksum       String?
  lastSyncedAt   DateTime?
  createdAt      DateTime @default(now())

  @@unique([sourceSystem, entityType, legacyId])
  @@index([entityType, newId])
}
